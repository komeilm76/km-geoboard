{
  "name": "@komeilm76/km-shared",
  "version": "0.1.2",
  "type": "module",
  "description": "Shared types and Zod utilities for km-packages — Result<T>, ResultError, and schema factory functions.",
  "license": "MIT",
  "author": "komeilm76",
  "homepage": "https://github.com/komeilm76/km-geoboard/tree/main/packages/km-shared#readme",
  "bugs": {
    "url": "https://github.com/komeilm76/km-geoboard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komeilm76/km-geoboard.git",
    "directory": "packages/km-shared"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "check-zod": "node ../../scripts/check-zod.mjs"
  },
  "peerDependencies": {
    "zod": ">=4.4.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.2",
    "vitest": "^2.0.0",
    "zod": "^4.4.0"
  },
  "keywords": [
    "typescript",
    "zod",
    "result",
    "km-packages"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
