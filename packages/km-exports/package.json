{
  "name": "@komeilm76/km-exports",
  "version": "0.1.3",
  "description": "Serialization functions that convert artboard and map content into SVG, GeoJSON, OpenLayers, PDF metadata, and raster draw instructions.",
  "license": "MIT",
  "author": "komeilm76",
  "homepage": "https://github.com/komeilm76/km-geoboard/tree/main/packages/km-exports#readme",
  "bugs": {
    "url": "https://github.com/komeilm76/km-geoboard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komeilm76/km-geoboard.git",
    "directory": "packages/km-exports"
  },
  "keywords": [
    "svg",
    "geojson",
    "openlayers",
    "pdf",
    "raster",
    "export",
    "serialization"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "fix:prettier": "prettier --write \"src/**/*.{ts,json}\"",
    "fix": "pnpm run fix:prettier",
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check-zod": "node ../../scripts/check-zod.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@komeilm76/km-shared": "workspace:*",
    "@komeilm76/km-artboard": "workspace:*",
    "@komeilm76/km-geojson": "workspace:*",
    "@komeilm76/km-svg": "workspace:*"
  },
  "peerDependencies": {
    "zod": ">=4.4.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.2",
    "vitest": "^2.0.0",
    "zod": "^4.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  }
}
