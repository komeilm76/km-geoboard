{
  "name": "@komeilm76/km-svg",
  "version": "0.1.0",
  "type": "module",
  "description": "SVG content as structured data \u2014 parse SVG XML into typed element trees, manipulate paths, and convert SVG geometry to GeoJSON.",
  "license": "MIT",
  "author": "komeilm76",
  "homepage": "https://github.com/komeilm76/km-geoboard/tree/main/packages/km-svg#readme",
  "bugs": {
    "url": "https://github.com/komeilm76/km-geoboard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komeilm76/km-geoboard.git",
    "directory": "packages/km-svg"
  },
  "keywords": [
    "svg",
    "geojson",
    "gis",
    "typescript",
    "zod",
    "km-packages"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "check-zod": "node ../../scripts/check-zod.mjs"
  },
  "dependencies": {
    "fast-xml-parser": "^4.4.0",
    "@komeilm76/km-geojson": "workspace:*",
    "@komeilm76/km-shared": "workspace:*"
  },
  "peerDependencies": {
    "zod": ">=4.4.0"
  },
  "devDependencies": {
    "zod": "^4.4.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
